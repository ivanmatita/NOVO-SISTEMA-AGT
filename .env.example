# Configurações de API (Obrigatório para funcionalidades de IA)
GEMINI_API_KEY=sua_chave_aqui

# Configurações de Banco de Dados (Recomendado para Produção em 2026)
VITE_SUPABASE_URL=https://xxxx.supabase.co
VITE_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Ambiente
NODE_ENV=production
VITE_APP_URL=https://seu-projeto.vercel.app

# =========================
# AGT - FACTURAÇÃO ELECTRÓNICA
# IMATEC SOFT ERP
# =========================

# Credenciais AGT (NUNCA expor no frontend)
AGT_USERNAME=
AGT_PASSWORD=

# URL AGT (HOMOLOGAÇÃO - TESTE)
AGT_VALIDATION_URL=https://sifphml.minfin.gov.ao/sigt/fe/v1/validarDocumento

# OU PRODUÇÃO (descomentar quando estiver em produção)
# AGT_VALIDATION_URL=https://sifp.minfin.gov.ao/sigt/fe/v1/validarDocumento


# =========================
# SOFTWARE INFO (AGT)
# =========================
AGT_SOFTWARE_INFO_DETAIL={"productId":"IMATEC SOFT ERP","productVersion":"1.0.0","softwareValidationNumber":"C_134"}


# =========================
# CHAVES RSA (ASSINATURA)
# =========================

AGT_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nSUA_CHAVE_PRIVADA_AQUI\n-----END PRIVATE KEY-----"

AGT_PUBLIC_KEY="-----BEGIN PUBLIC KEY-----\nSUA_CHAVE_PUBLICA_AQUI\n-----END PUBLIC KEY-----"


# =========================
# SEGURANÇA / CONFIGURAÇÃO
# =========================

# Ambiente (development | production)
NODE_ENV=development

# Modo AGT (LIVE para servidores reais ou SANDBOX para simulação local robusta)
VITE_AGT_MODE=SANDBOX

# Timeout pedidos AGT (ms)
AGT_TIMEOUT=15000

# Número de tentativas automáticas
AGT_RETRY_COUNT=3
